# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Chave secreta para JWT (mínimo 32 caracteres)
SECRET_KEY=your-secret-key-min-32-characters-here

# Provedor de IA: GROQ ou OLLAMA
AI_PROVIDER=GROQ

# Groq (usado quando AI_PROVIDER=GROQ)
# Obtenha sua chave em: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (usado quando AI_PROVIDER=OLLAMA)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b-instruct
